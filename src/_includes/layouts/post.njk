---
layout: layouts/base.njk
---
<article class="post">
  <header class="post-header">
    <h1>{{ title }}</h1>
    {% if date %}<time datetime="{{ date | dateDisplay }}">{{ date | dateDisplay }}</time>{% endif %}
    {% if tags %}
    <ul class="tags">
      {% for tag in tags %}
        {% if tag != "post" %}<li>{{ tag }}</li>{% endif %}
      {% endfor %}
    </ul>
    {% endif %}
  </header>
  <div class="post-body">
    {{ content | safe }}
  </div>
</article>
