<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title %}{{ title }} — {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}" />
  <link rel="stylesheet" href="/assets/css/style.css" />
  <link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="/feed.xml" />
</head>
<body>
  <header>
    <a href="/" class="site-name">{{ site.title }}</a>
    <nav>
      {% for item in site.nav %}
        <a href="{{ item.url }}"{% if page.url == item.url %} aria-current="page"{% endif %}>{{ item.label }}</a>
      {% endfor %}
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    <p>© {{ site.author }} — <a href="{{ site.url }}">{{ site.url }}</a></p>
  </footer>
</body>
</html>
