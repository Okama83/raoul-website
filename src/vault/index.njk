---
layout: layouts/base.njk
title: Vault
---
<section class="listing">
  <h1 class="section-label">Vault</h1>
  <p class="section-desc">Copyright-free game design documents — hosted, annotated, and worth studying.</p>

  {% if collections.vault.length %}
  <ul class="project-list">
    {% for entry in collections.vault %}
    <li>
      <a href="{{ entry.url }}">{{ entry.data.title }}</a>
      {% if entry.data.year %}<span class="year">{{ entry.data.year }}</span>{% endif %}
      {% if entry.data.game %}<span class="status">{{ entry.data.game }}{% if entry.data.studio %} · {{ entry.data.studio }}{% endif %}</span>{% endif %}
      {% if entry.data.description %}<p>{{ entry.data.description }}</p>{% endif %}
    </li>
    {% endfor %}
  </ul>
  {% else %}
  <p class="empty-state">[ VAULT EMPTY ]<br>// ACQUIRING DOCUMENTS...<br>// ACCESS WILL BE GRANTED</p>
  {% endif %}
</section>
