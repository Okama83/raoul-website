---
layout: layouts/base.njk
title: Home
---
<section class="home">
  <p class="home-name">Raoul Paraschiv</p>
  <p class="home-tagline">Game designer. Thinking out loud about systems, tools, and craft.</p>

  <div class="home-sections">
    <div>
      <a href="/lab/" class="home-section-label">Lab</a>
      <p class="home-section-desc">Active projects and works in progress.</p>
    </div>
    <div>
      <a href="/vault/" class="home-section-label">Vault</a>
      <p class="home-section-desc">Completed games and released work.</p>
    </div>
    <div>
      <a href="/commonplace/" class="home-section-label">Commonplace Book</a>
      <p class="home-section-desc">Notes on game design, tools, pipelines, and the rest.</p>
      {% if collections.posts.length %}
      <ul class="recent-posts">
        {% for post in collections.posts | reverse | slice(0, 3) %}
          <li>
            <a href="{{ post.url }}">{{ post.data.title }}</a>
            <time>{{ post.date | dateDisplay }}</time>
          </li>
        {% endfor %}
      </ul>
      {% endif %}
    </div>
  </div>
</section>
